# ─── Sources RTSP du robot ────────────────────────────────────────────────────
# URL complètes des flux RTSP des 2 caméras embarquées sur le robot
CAM1_SOURCE=rtsp://192.168.1.100:8554/cam1
CAM2_SOURCE=rtsp://192.168.1.100:8554/cam2

# ─── Ports exposés ────────────────────────────────────────────────────────────
# Port RTSP de la passerelle (accès : rtsp://GATEWAY_IP:48554/cam1)
RTSP_PORT=48554
# Port HLS (accès : http://GATEWAY_IP:48888/cam1)
HLS_PORT=48888
# Port WebRTC (accès : http://GATEWAY_IP:48889/cam1)
WEBRTC_PORT=48889

# ─── API & Sécurité ───────────────────────────────────────────────────────────
# Port HTTPS du serveur de reconnaissance faciale, MyGES et CORE State
# API docs : https://GATEWAY_IP:44888/docs
FACE_SERVER_PORT=44888

# Token de sécurité obligatoire pour communiquer avec l'API
API_TOKEN=bastet-super-secret-token
